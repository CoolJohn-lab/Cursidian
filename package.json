{
  "name": "cursidian",
  "version": "2.6.2",
  "description": "MCP server for Obsidian vaults, optimised for Cursor agents - safe writes, lean tool surface, direct filesystem access.",
  "type": "module",
  "bin": {
    "cursidian": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "npm run slop:check",
    "slop:check": "node scripts/slop-check.mjs",
    "slop:fix": "node scripts/fix-slop.mjs",
    "slop:check:wiki": "node scripts/slop-check.mjs --wiki",
    "slop:fix:wiki": "node scripts/fix-slop.mjs --wiki",
    "smoke": "node scripts/smoke-test.mjs",
    "mcp:test": "node scripts/mcp-test.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run --coverage",
    "test:clean": "node scripts/clean-npm-env.mjs vitest run --coverage",
    "test:fast": "vitest run",
    "test:file": "vitest run --coverage.enabled=false",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/clean-npm-env.mjs npm run verify:inner",
    "verify:inner": "node scripts/run-verify-inner.mjs",
    "prepublishOnly": "node scripts/clean-npm-env.mjs node scripts/run-verify-inner.mjs",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "bump": "node scripts/bump-version.mjs",
    "skills:install": "node scripts/install-skills.mjs",
    "skills:install:dry": "node scripts/install-skills.mjs --dry-run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "cursor",
    "cursidian",
    "notes",
    "knowledge-management",
    "ai"
  ],
  "author": "Cool John",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CoolJohn-lab/Cursidian.git"
  },
  "bugs": {
    "url": "https://github.com/CoolJohn-lab/Cursidian/issues"
  },
  "homepage": "https://github.com/CoolJohn-lab/Cursidian#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "stemmer": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.1.3",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.26.0",
    "llm-slop-detector": "^0.10.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
